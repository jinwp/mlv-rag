# Copy this file to .env.local for local development.
# Never commit .env.local or real secrets.

# Supabase client config. These NEXT_PUBLIC_* values are visible to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# OpenAI server-only config. Do not prefix this key with NEXT_PUBLIC_.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_WEB_SEARCH_MODEL=gpt-5.4-mini
OPENAI_REWRITE_MODEL=gpt-5.5
OPENAI_OCR_MODEL=gpt-5.5
OPENAI_IMAGE_MODEL=gpt-image-2

# STT provider config.
STT_PROVIDER=clova
NAVER_CLOVA_SPEECH_SECRET=
NAVER_CLOVA_SPEECH_INVOKE_URL=
